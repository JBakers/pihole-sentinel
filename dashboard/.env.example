# Monitor Environment Configuration
# ============================
#
# IMPORTANT: This file contains example values that MUST be changed!
# 1. Copy this file to .env in the monitor directory
# 2. Update ALL IP addresses and passwords below
#
# Network Configuration
# -------------------
# The following IP addresses are EXAMPLES and must be changed:

# Primary Pi-hole Configuration
PRIMARY_IP=192.168.1.10         # Change to your Primary Pi-hole's actual IP
PRIMARY_NAME="Primary Pi-hole"   # You can customize this name
PRIMARY_PASSWORD=CHANGE_THIS     # Change to your Primary Pi-hole's API password

# Secondary Pi-hole Configuration
SECONDARY_IP=192.168.1.11       # Change to your Secondary Pi-hole's actual IP
SECONDARY_NAME="Secondary Pi-hole" # You can customize this name
SECONDARY_PASSWORD=CHANGE_THIS   # Change to your Secondary Pi-hole's API password

# Virtual IP (VIP) Configuration
# This MUST match the VIP_ADDRESS in your keepalived configuration
VIP_ADDRESS=192.168.1.2         # Change to match your keepalived VIP

# Monitor Settings
# These can usually stay as default values
CHECK_INTERVAL=10               # Seconds between checks
DB_PATH=/opt/pihole-monitor/monitor.db

# API Security
# Leave empty to auto-generate on first run, or set your own secure key
API_KEY=

# Database Cleanup Settings
# Automatically delete old records to prevent database growth
RETENTION_DAYS_HISTORY=30   # Keep status_history records for 30 days
RETENTION_DAYS_EVENTS=90    # Keep events for 90 days

# SSH Access to Pi-holes (for automatic DHCP failover push)
# These are set automatically by setup.py — only configure manually
# if you need to override the defaults.
SSH_KEY_PATH=/opt/pihole-monitor/.ssh/id_pihole_sentinel
PRIMARY_SSH_USER=root
PRIMARY_SSH_PORT=22
SECONDARY_SSH_USER=root
SECONDARY_SSH_PORT=22

# Advanced Settings
# Notification config file path (default: alongside monitor.db)
# NOTIFY_CONFIG_PATH=/opt/pihole-monitor/notify_settings.json

# Reverse proxy support — only enable if behind a trusted proxy
# TRUST_PROXY_HEADERS=false

# Event debounce — suppress duplicate events within this window (seconds)
# EVENT_DEBOUNCE_SECONDS=30

# DNS latency threshold — warn when DNS response exceeds this value (milliseconds)
# DNS_LATENCY_WARN_MS=500

# Debug / test mode — enables POST /api/debug/override to simulate node outages
# WARNING: never enable this in production
# DEBUG_MODE=false