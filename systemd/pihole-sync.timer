[Unit]
Description=Pi-hole Configuration Sync Timer
Requires=pihole-sync.service

[Timer]
# Default: every 10 minutes (configurable via deploy_sync in setup.py)
OnCalendar=*:0/10
# Run 2 minutes after boot
OnBootSec=2min
# If system was offline during scheduled time, run immediately
Persistent=true

[Install]
WantedBy=timers.target
